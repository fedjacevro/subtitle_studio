<Window x:Class="SubtitleStudio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SubtitleStudio.App.Views"
        xmlns:converters="clr-namespace:SubtitleStudio.App.Converters"
        mc:Ignorable="d"
        Title="Subtitle Studio"
        Height="800"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        FontSize="14">
    <Window.Resources>
        <ResourceDictionary>
            <converters:StepToVisibilityConverter x:Key="StepToVisibilityConverter" />
            <converters:StepToBackgroundConverter x:Key="StepToBackgroundConverter" />
            <converters:StepToBorderConverter x:Key="StepToBorderConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Logo/Title -->
                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceLightBrush}"
                        Padding="20,24"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="&#xE714;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Margin="0,0,0,8"
                                   FontSize="32"
                                   Foreground="{StaticResource AccentBrush}"
                                   TextAlignment="Center" />
                        <TextBlock Text="Subtitle Studio"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Navigation Items -->
                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <!-- Step 1: Source -->
                    <Button Command="{Binding NavigateToCommand}"
                            CommandParameter="0"
                            Background="{Binding CurrentStep, Converter={StaticResource StepToBackgroundConverter}, ConverterParameter=0}"
                            Style="{StaticResource SecondaryButton}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="{Binding CurrentStep, Converter={StaticResource StepToBorderConverter}, ConverterParameter=0}"
                            HorizontalContentAlignment="Left"
                            Padding="16,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B2;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                     Margin="0,0,12,0" Foreground="{StaticResource AccentLightBrush}" MinWidth="20" />
                            <StackPanel>
                                <TextBlock Text="Source" FontWeight="SemiBold" />
                                <TextBlock Text="Load video" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Step 2: Transcribe -->
                    <Button Command="{Binding NavigateToCommand}"
                            CommandParameter="1"
                            Background="{Binding CurrentStep, Converter={StaticResource StepToBackgroundConverter}, ConverterParameter=1}"
                            Style="{StaticResource SecondaryButton}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="{Binding CurrentStep, Converter={StaticResource StepToBorderConverter}, ConverterParameter=1}"
                            HorizontalContentAlignment="Left"
                            Padding="16,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                     Margin="0,0,12,0" Foreground="{StaticResource AccentLightBrush}" MinWidth="20" />
                            <StackPanel>
                                <TextBlock Text="Transcribe" FontWeight="SemiBold" />
                                <TextBlock Text="Generate subtitles" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Step 3: Edit Subtitles -->
                    <Button Command="{Binding NavigateToCommand}"
                            CommandParameter="2"
                            Background="{Binding CurrentStep, Converter={StaticResource StepToBackgroundConverter}, ConverterParameter=2}"
                            Style="{StaticResource SecondaryButton}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="{Binding CurrentStep, Converter={StaticResource StepToBorderConverter}, ConverterParameter=2}"
                            HorizontalContentAlignment="Left"
                            Padding="16,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                     Margin="0,0,12,0" Foreground="{StaticResource AccentLightBrush}" MinWidth="20" />
                            <StackPanel>
                                <TextBlock Text="Edit" FontWeight="SemiBold" />
                                <TextBlock Text="Review &amp; adjust" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Step 4: Translate -->
                    <Button Command="{Binding NavigateToCommand}"
                            CommandParameter="3"
                            Background="{Binding CurrentStep, Converter={StaticResource StepToBackgroundConverter}, ConverterParameter=3}"
                            Style="{StaticResource SecondaryButton}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="{Binding CurrentStep, Converter={StaticResource StepToBorderConverter}, ConverterParameter=3}"
                            HorizontalContentAlignment="Left"
                            Padding="16,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE775;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                     Margin="0,0,12,0" Foreground="{StaticResource AccentLightBrush}" MinWidth="20" />
                            <StackPanel>
                                <TextBlock Text="Translate" FontWeight="SemiBold" />
                                <TextBlock Text="Multi-language" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Step 5: Export -->
                    <Button Command="{Binding NavigateToCommand}"
                            CommandParameter="4"
                            Background="{Binding CurrentStep, Converter={StaticResource StepToBackgroundConverter}, ConverterParameter=4}"
                            Style="{StaticResource SecondaryButton}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="{Binding CurrentStep, Converter={StaticResource StepToBorderConverter}, ConverterParameter=4}"
                            HorizontalContentAlignment="Left"
                            Padding="16,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                     Margin="0,0,12,0" Foreground="{StaticResource AccentLightBrush}" MinWidth="20" />
                            <StackPanel>
                                <TextBlock Text="Export" FontWeight="SemiBold" />
                                <TextBlock Text="SRT/VTT/Burn-in" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Separator -->
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="16,8" />

                    <!-- Settings -->
                    <Button Command="{Binding NavigateToCommand}"
                            CommandParameter="5"
                            Background="{Binding CurrentStep, Converter={StaticResource StepToBackgroundConverter}, ConverterParameter=5}"
                            Style="{StaticResource SecondaryButton}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="{Binding CurrentStep, Converter={StaticResource StepToBorderConverter}, ConverterParameter=5}"
                            HorizontalContentAlignment="Left"
                            Padding="16,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;"
                                     Margin="0,0,12,0" FontSize="18" MinWidth="20" TextAlignment="Center" />
                            <StackPanel>
                                <TextBlock Text="Settings" FontWeight="SemiBold" />
                                <TextBlock Text="Model management" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Bottom status -->
                <Border Grid.Row="2"
                        Padding="16,12"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <TextBlock Text="Subtitle Studio v1.0"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    Padding="24,16"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentStepName, StringFormat='{}{0}'}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Command="{Binding PreviousStepCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="12,6"
                                FontSize="12"
                                Content="← Previous" Margin="0,0,8,0" />
                        <Button Command="{Binding NextStepCommand}"
                                Padding="12,6"
                                FontSize="12"
                                Content="Next →" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <views:SourceView Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=0}" />
                <views:TranscribeView Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=1}" />
                <views:EditSubtitlesView Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=2}" />
                <views:TranslateView Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=3}" />
                <views:ExportView Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=4}" />
                <views:SettingsView Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=5}" />
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    Padding="24,8"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding GlobalStatus}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <ProgressBar Grid.Column="1"
                                 Width="120"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Margin="16,0,0,0"
                                 Visibility="{Binding IsOperationRunning, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
