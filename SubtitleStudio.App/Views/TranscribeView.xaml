<UserControl x:Class="SubtitleStudio.App.Views.TranscribeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Step 2: Transcribe"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,8" />
            <TextBlock Text="Transcribe audio to subtitles using Whisper"
                       FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,24" />

            <!-- Video Info -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16"
                    Visibility="{Binding VideoFilePath, Converter={StaticResource NullToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Video loaded:"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="{Binding VideoFilePath, Converter={StaticResource FileNameConverter}}"
                               FontSize="16"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <!-- Start Transcription -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Start Transcription"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Click the button below to extract audio and transcribe it to subtitles."
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />
                    <Button Command="{Binding StartTranscriptionCommand}"
                            IsEnabled="{Binding IsTranscribing, Converter={StaticResource InverseBoolConverter}}"
                            HorizontalAlignment="Left"
                            Padding="24,12"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F399;" FontSize="16" Margin="0,0,8,0" />
                            <TextBlock Text="Start Transcription" />
                        </StackPanel>
                    </Button>

                    <!-- Progress -->
                    <StackPanel Visibility="{Binding IsTranscribing, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar Value="{Binding TranscriptionProgress}"
                                     Maximum="1.0"
                                     Margin="0,0,0,4" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Results Preview -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16"
                    Visibility="{Binding SubtitleTrack, Converter={StaticResource NullToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Transcription Results"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="14"
                               Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding SubtitleTrack.Items}"
                                  MaxHeight="300">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4"
                                        Background="{StaticResource SurfaceLightBrush}"
                                        CornerRadius="4"
                                        Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index}"
                                                   FontWeight="Bold"
                                                   Margin="0,0,12,0"
                                                   Foreground="{StaticResource AccentLightBrush}"
                                                   MinWidth="30" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,12,0"
                                                   MinWidth="140">
                                            <Run Text="{Binding StartTime, StringFormat={}{0:hh\\:mm\\:ss\\,fff}}" />
                                            <Run Text=" → " />
                                            <Run Text="{Binding EndTime, StringFormat={}{0:hh\\:mm\\:ss\\,fff}}" />
                                        </TextBlock>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Text}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="40" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
