<UserControl x:Class="SubtitleStudio.App.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Step 5: Export"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,8" />
            <TextBlock Text="Export subtitles or burn them into the video"
                       FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,24" />

            <!-- Export Settings -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Export Settings"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <!-- Format -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Format:" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Formats}"
                                  SelectedItem="{Binding SelectedFormat}"
                                  HorizontalAlignment="Left"
                                  MinWidth="150" />
                    </Grid>

                    <!-- Use Proofread -->
                    <CheckBox IsChecked="{Binding UseProofread}"
                              Content="Use proofread text (if available)"
                              Margin="0,0,0,16" />

                    <!-- Burn-in Options -->
                    <Expander Header="Burned-in Subtitle Options"
                              Foreground="{StaticResource TextBrush}"
                              Background="{StaticResource SurfaceLightBrush}"
                              BorderBrush="{StaticResource BorderBrush}"
                              BorderThickness="1"
                              Padding="12"
                              Margin="0,0,0,16">
                        <StackPanel Margin="0,12,0,0">
                            <CheckBox IsChecked="{Binding BurnIntoVideo}"
                                      Content="Burn subtitles into video (creates new file)"
                                      Margin="0,0,0,12" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Font:" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding FontName}"
                                         HorizontalAlignment="Left"
                                         MinWidth="200" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Font Size:" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding FontSize}"
                                         HorizontalAlignment="Left"
                                         MinWidth="100" />
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- Export Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Command="{Binding ExportSubtitlesCommand}"
                                IsEnabled="{Binding IsExporting, Converter={StaticResource InverseBoolConverter}}"
                                Padding="24,12"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4E4;" FontSize="16" Margin="0,0,8,0" />
                                <TextBlock Text="Export Subtitles" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportAllCommand}"
                                Style="{StaticResource SecondaryButton}"
                                IsEnabled="{Binding IsExporting, Converter={StaticResource InverseBoolConverter}}"
                                Padding="24,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4E6;" FontSize="16" Margin="0,0,8,0" />
                                <TextBlock Text="Batch Export All" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Progress -->
                    <StackPanel Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar Value="{Binding ExportProgress}" Maximum="1.0" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Last Export -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16"
                    Visibility="{Binding LastExportPath, Converter={StaticResource NullToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Last Export"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding LastExportPath}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
