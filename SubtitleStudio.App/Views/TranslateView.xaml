<UserControl x:Class="SubtitleStudio.App.Views.TranslateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Step 4: Translate"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,8" />
            <TextBlock Text="Translate subtitles to another language using local LLM"
                       FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,24" />

            <!-- Model Status -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="LLM Model Status"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="{StaticResource SuccessBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                Visibility="{Binding IsLlmModelReady, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0">
                            <TextBlock Text="Model Ready" Foreground="White" FontSize="12" />
                        </Border>
                        <Border Background="{StaticResource WarningBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                Visibility="{Binding IsLlmModelReady, Converter={StaticResource InverseBoolVisibilityConverter}}"
                                Margin="0,0,8,0">
                            <TextBlock Text="Model Not Downloaded" Foreground="White" FontSize="12" />
                        </Border>
                        <Button Command="{Binding DownloadModelCommand}"
                                IsEnabled="{Binding IsDownloadingModel, Converter={StaticResource InverseBoolConverter}}"
                                Visibility="{Binding IsLlmModelReady, Converter={StaticResource InverseBoolVisibilityConverter}}"
                                Padding="12,6"
                                FontSize="12"
                                Content="Download LLM Model (~2GB)" />
                    </StackPanel>
                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{Binding IsDownloadingModel, Converter={StaticResource BoolToVisibility}}"
                                 Margin="0,0,0,4" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" />
                    <TextBlock Text="{Binding MemoryWarning}"
                               Foreground="{StaticResource WarningBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Visibility="{Binding MemoryWarning, Converter={StaticResource NullToVisibility}}" />
                </StackPanel>
            </Border>

            <!-- Language Selection & Translation -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Target Language"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />
                    <ComboBox ItemsSource="{Binding TargetLanguages}"
                              SelectedItem="{Binding SelectedTargetLanguage}"
                              DisplayMemberPath="NativeName"
                              HorizontalAlignment="Left"
                              MinWidth="200"
                              Margin="0,0,0,12" />

                    <TextBlock Text="Batch translate (select multiple):"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding LanguageOptions}"
                                  Margin="0,0,0,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected}"
                                          Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Command="{Binding TranslateCommand}"
                                IsEnabled="{Binding IsTranslating, Converter={StaticResource InverseBoolConverter}}"
                                Padding="20,10"
                                Content="Translate"
                                Margin="0,0,8,0" />
                        <Button Command="{Binding TranslateSelectedLanguagesCommand}"
                                Style="{StaticResource SecondaryButton}"
                                IsEnabled="{Binding IsTranslating, Converter={StaticResource InverseBoolConverter}}"
                                Padding="20,10"
                                Content="Translate Selected"
                                Margin="0,0,8,0" />
                        <Button Command="{Binding ProofreadCommand}"
                                Style="{StaticResource SecondaryButton}"
                                IsEnabled="{Binding IsProofreading, Converter={StaticResource InverseBoolConverter}}"
                                Padding="20,10"
                                Content="Proofread" />
                    </StackPanel>

                    <!-- Translation Progress -->
                    <StackPanel Visibility="{Binding IsTranslating, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar Value="{Binding TranslationProgress}" Maximum="1.0" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Side-by-side Preview -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16"
                    Visibility="{Binding TranslationComplete, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Translation Preview"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="14"
                               Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Original -->
                        <Border Grid.Column="0"
                                Background="{StaticResource SurfaceLightBrush}"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Original"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentLightBrush}"
                                           Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding OriginalItems}"
                                              MaxHeight="300">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4" Margin="0,1">
                                                <TextBlock Text="{Binding Text}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Separator -->
                        <TextBlock Grid.Column="1"
                                   Text="→"
                                   FontSize="24"
                                   VerticalAlignment="Center"
                                   Margin="16,0"
                                   Foreground="{StaticResource AccentBrush}" />

                        <!-- Translated -->
                        <Border Grid.Column="2"
                                Background="{StaticResource SurfaceLightBrush}"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Translated"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentLightBrush}"
                                           Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding TranslatedItems}"
                                              MaxHeight="300">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4" Margin="0,1">
                                                <TextBlock Text="{Binding DisplayText}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
