<UserControl x:Class="SubtitleStudio.App.Views.SourceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel>
            <TextBlock Text="Step 1: Source"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,8" />
            <TextBlock Text="Load a video file and configure transcription settings"
                       FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,24" />

            <!-- FFmpeg Status -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="FFmpeg Status"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource SuccessBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                Visibility="{Binding IsFfmpegAvailable, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0">
                            <TextBlock Text="FFmpeg Available" Foreground="White" FontSize="12" />
                        </Border>
                        <Border Background="{StaticResource ErrorBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                Visibility="{Binding IsFfmpegAvailable, Converter={StaticResource InverseBoolVisibilityConverter}}"
                                Margin="0,0,8,0">
                            <TextBlock Text="FFmpeg Not Available" Foreground="White" FontSize="12" />
                        </Border>
                        <Button Command="{Binding DownloadFfmpegCommand}"
                                Visibility="{Binding IsFfmpegAvailable, Converter={StaticResource InverseBoolVisibilityConverter}}"
                                Padding="12,6"
                                FontSize="12"
                                Content="Download FFmpeg" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Video Selection -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource SurfaceLightBrush}"
                            CornerRadius="8"
                            Margin="0,0,16,0"
                            MinHeight="120">
                        <Grid>
                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToImageConverter}}"
                                   Stretch="UniformToFill" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Video File"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="{Binding VideoFileName}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding VideoSummary}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"
                                   Visibility="{Binding VideoSummary, Converter={StaticResource NullToVisibility}}" />
                        <Button Command="{Binding SelectVideoCommand}"
                                Content="Browse Video Files"
                                HorizontalAlignment="Left"
                                IsEnabled="{Binding IsLoadingVideo, Converter={StaticResource InverseBoolConverter}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Model Selection -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Whisper Model"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />
                    <ComboBox ItemsSource="{Binding ModelSizes}"
                              SelectedValuePath="Size"
                              SelectedValue="{Binding SelectedModelSize}"
                              DisplayMemberPath="DisplayName"
                              HorizontalAlignment="Left"
                              MinWidth="300"
                              Margin="0,0,0,12" />
                    <Button Command="{Binding DownloadWhisperModelCommand}"
                            Content="Download Model"
                            HorizontalAlignment="Left"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                </StackPanel>
            </Border>

            <!-- Language Selection -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Source Language"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Select the audio language for better accuracy, or leave as Auto-detect"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,12" />
                    <ComboBox ItemsSource="{Binding SourceLanguages}"
                              SelectedItem="{Binding SelectedSourceLanguage}"
                              HorizontalAlignment="Left"
                              MinWidth="200" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>