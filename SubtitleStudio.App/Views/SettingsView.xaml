<UserControl x:Class="SubtitleStudio.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel>
            <TextBlock Text="Settings &amp; Model Management"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,8" />
            <TextBlock Text="Manage AI models, tools, and application data"
                       FontSize="16"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,24" />

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="System" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding MemoryStatus}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding OpenModelsFolderCommand}" Style="{StaticResource SecondaryButton}" Content="Open Models Folder" Margin="0,0,8,0" />
                        <Button Command="{Binding OpenLogsFolderCommand}" Style="{StaticResource SecondaryButton}" Content="Open Logs Folder" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Whisper Models" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <DataGrid ItemsSource="{Binding WhisperModels}"
                              SelectedItem="{Binding SelectedWhisperModelInfo}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Model" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Size" Binding="{Binding FileSizeDisplay}" Width="120" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding ModelSizes}" SelectedValuePath="Size"
                                  SelectedValue="{Binding SelectedWhisperModel}" DisplayMemberPath="DisplayName" MinWidth="250" />
                        <Button Grid.Column="1" Command="{Binding DownloadWhisperModelCommand}" Content="Download" Margin="12,0,8,0"
                                IsEnabled="{Binding IsDownloadingWhisper, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="2" Command="{Binding DeleteSelectedWhisperModelCommand}" Style="{StaticResource DangerButton}" Content="Delete" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="LLM Model" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <DataGrid ItemsSource="{Binding LlmModels}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Model" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Size" Binding="{Binding FileSizeDisplay}" Width="120" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding DownloadLlmModelCommand}" Content="Download LLM (~2GB)" Margin="0,0,8,0"
                                IsEnabled="{Binding IsDownloadingLlm, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Command="{Binding DeleteLlmModelCommand}" Style="{StaticResource DangerButton}" Content="Delete" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="FFmpeg" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource SuccessBrush}" CornerRadius="4" Padding="8,4"
                                Visibility="{Binding IsFfmpegAvailable, Converter={StaticResource BoolToVisibility}}" Margin="0,0,8,0">
                            <TextBlock Text="Available" Foreground="White" FontSize="12" />
                        </Border>
                        <Border Background="{StaticResource ErrorBrush}" CornerRadius="4" Padding="8,4"
                                Visibility="{Binding IsFfmpegAvailable, Converter={StaticResource InverseBoolVisibilityConverter}}">
                            <TextBlock Text="Not Available" Foreground="White" FontSize="12" />
                        </Border>
                    </StackPanel>
                    <Button Command="{Binding DownloadFfmpegCommand}" Content="Download FFmpeg"
                            Visibility="{Binding IsFfmpegAvailable, Converter={StaticResource InverseBoolVisibilityConverter}}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="Application Info" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Subtitle Studio v1.0.0" Margin="0,0,0,4" />
                    <TextBlock Text="Built with .NET 10 + WPF · CPU-only AI pipeline" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding ModelsDirectory, StringFormat='Models: {0}'}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>